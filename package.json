{
  "name": "@aeroapp/ae",
  "version": "0.5.0",
  "description": "Tiny attribute-based behavior + reactivity library. HTML is the source of truth: one data-ae attribute, signals, keyed lists, two-way forms, View-Transition animation. No virtual DOM, no hydration, no build step required.",
  "keywords": [
    "reactivity",
    "signals",
    "dom",
    "binder",
    "frontend",
    "lightweight",
    "no-vdom",
    "view-transitions"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nft/ae.git"
  },
  "homepage": "https://nft.github.io/ae/",
  "bugs": "https://github.com/nft/ae/issues",
  "type": "module",
  "main": "dist/ae.js",
  "types": "dist/ae.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ae.d.ts",
      "import": "./dist/ae.js",
      "default": "./dist/ae.js"
    },
    "./min": "./dist/ae.min.js"
  },
  "unpkg": "dist/ae.min.js",
  "jsdelivr": "dist/ae.min.js",
  "files": [
    "dist",
    "src",
    "llms.txt"
  ],
  "sideEffects": true,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "bun run build && bun test/smoke.mjs",
    "serve": "bun scripts/serve.ts",
    "min": "bun build src/ae.ts --minify --outfile=dist/ae.min.js",
    "prepublishOnly": "bun run test && bun run min"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2"
  }
}
